# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=memo_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=memo_app
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Database URL for FastAPI
# Docker:  postgresql+asyncpg://memo_user:password@postgres:5432/memo_app
# Local:   postgresql+asyncpg://memo_user:password@localhost:5433/memo_app
DATABASE_URL=postgresql+asyncpg://memo_user:your_secure_password_here@postgres:5432/memo_app

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Kafka Configuration (for local development)
# ===========================================
# Docker: kafka:9093 (internal listener)
# Local:  localhost:9092 (external listener)
KAFKA_BOOTSTRAP_SERVERS=kafka:9093

# ===========================================
# AWS SQS Configuration (for AWS deployment)
# ===========================================
# Set EVENT_BACKEND to 'sqs' to use SQS instead of Kafka
EVENT_BACKEND=kafka
SQS_QUEUE_URL=
AWS_REGION=ap-northeast-2

# ===========================================
# Application Settings
# ===========================================
DEBUG=false
LOG_LEVEL=INFO

# ===========================================
# Security Settings (MUST change in production!)
# ===========================================
# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://sogangcomputerclub.org,https://www.sogangcomputerclub.org

# ===========================================
# Frontend Configuration
# ===========================================
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Google Calendar API (server-side only - no VITE_ prefix for security)
GOOGLE_API_KEY=your_google_api_key_here
CALENDAR_ID=your_calendar_id_here

# ===========================================
# Monitoring (Grafana)
# ===========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
GRAFANA_ROOT_URL=http://localhost:3001

# ===========================================
# Backup Configuration
# ===========================================
BACKUP_DIR=./backups
CONTAINER_NAME_PREFIX=sgcc